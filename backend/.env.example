# Kshanik Search Engine — Configuration
# Copy this file to .env and set your values.

# Server port
PORT=8080

# Timeout for individual provider API calls (milliseconds)
PROVIDER_TIMEOUT_MS=5000

# Timeout for the entire search operation (milliseconds)
SEARCH_TIMEOUT_MS=10000

# GitHub API token (optional — increases rate limit from 10 to 30 req/min)
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=
