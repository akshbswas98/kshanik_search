# Kshanik Search Engine — Configuration
# Copy to .env for local/docker. On Fly.io use: fly secrets set KEY=value

# development | production
ENV=development

PORT=8080
PROVIDER_TIMEOUT_MS=5000
SEARCH_TIMEOUT_MS=10000

# Public API hostname and Let's Encrypt contact for Caddy.
# A free DuckDNS subdomain is sufficient, for example api-kshanik.duckdns.org.
API_DOMAIN=api.example.com
ACME_EMAIL=you@example.com

# Comma-separated browser origins (required in production for Netlify CORS)
# Example: https://kshaniksearch.netlify.app,https://main--kshaniksearch.netlify.app
ALLOWED_ORIGINS=http://localhost:3000

RATE_LIMIT_PER_MINUTE=60
MAX_QUERY_LENGTH=200
EXPOSE_ERROR_DETAIL=false

# Optional — GitHub search rate limits: https://github.com/settings/tokens
GITHUB_TOKEN=
