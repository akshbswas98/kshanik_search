# Frontend (Vite) — copy to .env.local for local overrides only.
# Production: set in Netlify dashboard, NOT in committed files.

# Leave empty locally; Vite proxies /api to the Go server (see vite.config.js)
# VITE_BACKEND_URL=

# Netlify production example:
# VITE_BACKEND_URL=https://your-app.fly.dev
